# ============================================================
#  NEXO I+D · Constructora Independencia
#  Copiar a .env y ajustar valores
# ============================================================

# ── Base de datos ────────────────────────────────────────────
# Desarrollo (backend nativo + host.docker.internal):
DATABASE_URL="postgresql://postgres:TU_PASSWORD@host.docker.internal:5432/cii_comunicaciones"
# Producción (docker-compose.prod.yml gestiona esto automáticamente via POSTGRES_*):
# DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"

# Variables PostgreSQL (solo para docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-en-prod
POSTGRES_DB=nexo_id

# ── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET="cambiame-en-prod-secreto-largo-aleatorio"
JWT_REFRESH_SECRET="cambiame-en-prod-otro-secreto-distinto"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_COST=12

# ── CORS ─────────────────────────────────────────────────────
# Desarrollo:
CORS_ORIGIN="http://localhost:5173"
# Producción (dominio real):
# CORS_ORIGIN="https://nexo.cindependencia.cl"

# ── Puertos (solo desarrollo) ────────────────────────────────
BACKEND_PORT=4000
FRONTEND_PORT=5173
PGADMIN_PORT=5050

# ── Frontend ──────────────────────────────────────────────────
# Desarrollo: URL completa del backend
VITE_API_URL="http://localhost:4000"
# Producción con nginx proxy: dejar vacío (las llamadas a /api/... van al mismo origen)
# VITE_API_URL=""

# ── Puerto servidor (docker-compose.prod.yml) ─────────────────
PORT=80

# ── pgAdmin (solo desarrollo) ────────────────────────────────
PGADMIN_EMAIL="admin@cindependencia.cl"
PGADMIN_PASSWORD="admin"
